# ========================================
# DeforestNet .gitignore
# ========================================

# Byte-compiled / optimized
__pycache__/
*.py[codz]
*$py.class

# Generated outputs — exclude large binaries and large visualisation PNGs
outputs/gradcam/
outputs/predictions/
outputs/preprocessed/
outputs/**/*.npy
outputs/**/*.npz
outputs/**/*.json
# Exclude large generated visualization PNGs (auto-generated by scripts)
outputs/visualizations/

# Raw / processed data (large binary numpy arrays)
data/processed/
data/raw/
data/synthetic/*.npy
data/synthetic/*.npz

database/
logs/
models/checkpoints/

# Binary data files
*.npy
*.npz
*.pth
*.pt
*.h5
*.hdf5
*.db
*.sqlite3

# Environment & secrets
.env
.envrc

# Virtual environments
.venv/
venv/
env/
ENV/

# Non-project folders
Questions/
Photos/
PPT_DOCS/
ARCHITECTURE/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Testing
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.pytest_cache/
.cache

# Logs
*.log
pip-log.txt

# Misc
*.manifest
*.spec
.mypy_cache/
.ruff_cache/
.pypirc
